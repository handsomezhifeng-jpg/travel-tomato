{
    "name": "旅游番茄钟",
    "appid": "__UNI__TRAVELTOMATO",
    "description": "旅游番茄钟 - 用专注丈量世界",
    "versionName": "1.0.0",
    "versionCode": "100",
    "transformPx": false,
    "app-plus": {
        "usingComponents": true,
        "nvueStyleCompiler": "uni-app",
        "compilerVersion": 3,
